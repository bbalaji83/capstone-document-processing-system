# Groq API Key - get yours at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# App settings
APP_NAME=Capstone Document Processing System
APP_VERSION=1.0.0
APP_DESCRIPTION=AI-powered document Q&A system using RAG and ReActAgent
DEBUG=True

# ChromaDB settings
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=documents

# Upload settings
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,txt,csv,xlsx,json,yaml

# LLM settings
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# Embedding settings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Retrieval settings
TOP_K_RESULTS=5
CHUNK_SIZE=512
CHUNK_OVERLAP=50